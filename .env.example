# ─────────────────────────────────────────────────────────────
# Vuka Afrique — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# PostgreSQL direct connection string
DATABASE_URL="postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres"

# ── Redis (Upstash) ─────────────────────────────────────────
# Upstash Redis REST API URL
# Format: redis://default:TOKEN@UPSTASH_HOST:PORT
REDIS_URL="redis://default:your-redis-token@upstash-host:6379"

# ── Supabase ────────────────────────────────────────────────
# Vite frontend variables
VITE_SUPABASE_URL="https://yghndmkuogaepegibxhd.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
# NOTE: VITE_SUPABASE_SERVICE_ROLE_KEY has been removed.
# The frontend now uses the anon key + RLS policies only.

# Backend variables (workers)
NEXT_PUBLIC_SUPABASE_URL="https://yghndmkuogaepegibxhd.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Used only by scripts/apply-migration.mjs (direct pooler connection for
# running one-off migration scripts outside the Supabase CLI)
SUPABASE_PROJECT_REF="your-project-ref"
SUPABASE_DB_PASSWORD="your-db-password"

# Supabase Edge Functions (Deno)
# Deploy with: supabase functions deploy mpesa-stkpush --no-verify-jwt
#              supabase functions deploy mpesa-callback --no-verify-jwt
# The Edge Functions also need these env vars set via:
#   supabase secrets set MPESA_CONSUMER_KEY=...
#   supabase secrets set MPESA_CONSUMER_SECRET=...
#   supabase secrets set MPESA_PASSKEY=...
#   supabase secrets set MPESA_SHORTCODE=...
#   supabase secrets set MPESA_CALLBACK_URL=...
#   supabase secrets set MPESA_ENV=sandbox
#   supabase secrets set SENDGRID_API_KEY=...
#   supabase secrets set EMAIL_FROM="Vuka Afrique <noreply@vukaafrique.com>"
#   supabase secrets set SUPABASE_URL=...
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...

# ── CSRF Protection ──────────────────────────────────────────
# Secret for generating CSRF tokens (min 32 chars)
CSRF_SECRET="your-32-char-csrf-secret"

# ── Encryption (PII at rest) ─────────────────────────────────
# 32-byte key for AES-256-GCM encryption of sensitive fields
ENCRYPTION_KEY="your-32-byte-encryption-key"

# ── Email (SMTP / Resend) ───────────────────────────────────
EMAIL_HOST="smtp.resend.com"
EMAIL_PORT=465
EMAIL_USER="resend"
EMAIL_PASS="re_..."

# ── M-Pesa Daraja API ───────────────────────────────────────
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_PASSKEY="your-online-checkout-passkey"
MPESA_SHORTCODE="174379"
MPESA_B2C_SHORTCODE="600000"
MPESA_B2C_INITIATOR_NAME="apitest"
MPESA_B2C_SECURITY_CREDENTIAL="your-b2c-security-credential"
MPESA_ENV="sandbox"

# Callback URLs (must be HTTPS in production)
MPESA_CALLBACK_URL="https://your-domain.com/api/webhooks/mpesa/confirmation"
MPESA_B2C_RESULT_URL="https://your-domain.com/api/webhooks/mpesa/b2c-result"
MPESA_B2C_TIMEOUT_URL="https://your-domain.com/api/webhooks/mpesa/b2c-timeout"

# Safaricom callback IP whitelist (comma-separated)
MPESA_IP_WHITELIST="196.201.214.200,196.201.214.206,196.201.213.114,196.201.214.208,196.201.213.44,196.201.212.127,196.201.212.138,196.201.212.129,196.201.212.136,196.201.212.74,196.201.212.69"

# ── Cloudflare R2 ────────────────────────────────────────────
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="vuka-uploads"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://pub-your-account-id.r2.dev"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="/api/v1"
SESSION_ENCRYPTION_KEY="your-32-byte-session-key"

# ── BullMQ ───────────────────────────────────────────────────
BULLMQ_PREFIX="{vuka-queues}"

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
PAYOUT_RATE_LIMIT_MAX=2
PAYOUT_RATE_LIMIT_WINDOW_MS=3600000
ADMIN_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_WINDOW_MS=60000

# ── File Upload ─────────────────────────────────────────────
MAX_UPLOAD_SIZE=10485760        # 10MB for images/docs
MAX_VIDEO_UPLOAD_SIZE=52428800  # 50MB for videos
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,application/pdf,video/mp4"

# ── Feature Flags ───────────────────────────────────────────
MAINTENANCE_MODE="false"
DISABLE_SIGNUPS="false"
REQUIRE_EMAIL_VERIFICATION="false"

# ── Logging & Monitoring ────────────────────────────────────
LOG_LEVEL="info"
SENTRY_DSN=""

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"
