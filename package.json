{
  "name": "vuka",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx backend/prisma/seed.ts",
    "worker:mpesa": "tsx backend/workers/mpesa-worker.ts",
    "worker:milestone": "tsx backend/workers/milestone-worker.ts",
    "worker:payout": "tsx backend/workers/payout-worker.ts",
    "worker:email": "tsx backend/workers/email-worker.ts",
    "worker:cron": "tsx backend/workers/cron-worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@sentry/nextjs": "^10.63.0",
    "@serwist/next": "^9.0.0",
    "@serwist/sw": "^9.0.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.101.2",
    "@upstash/ratelimit": "^1.0.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.23.0",
    "next": "^14.2.35",
    "nodemailer": "^6.9.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.24",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "nock": "^14.0.0",
    "playwright": "^1.42.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.0",
    "supertest": "^6.3.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
